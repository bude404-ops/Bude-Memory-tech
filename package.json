{
  "name": "bude-memory",
  "version": "1.0.0",
  "description": "Drop-in memory layer for AI agents. Smarter than raw context windows. Lighter than naive RAG.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/api/server.js",
    "dev": "tsc --watch"
  },
  "keywords": ["ai", "memory", "agent", "rag", "context"],
  "author": "bude404-ops",
  "license": "MIT",
  "dependencies": {
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
